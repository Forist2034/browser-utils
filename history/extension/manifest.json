{
    "name": "browser utils history recorder",
    "description": "Browser sync history recorder",
    "manifest_version": 2,
    "version": "1.0",
    "browser_specific_settings": {
        "gecko": {
            "id": "browser-utils.history-recorder@Forist2034.github.com",
            "strict_min_version": "139.0",
            "data_collection_permissions": {
                "required": [
                    "browsingActivity"
                ]
            }
        }
    },
    "background": {
        "persistent": true,
        "scripts": [
            "background.js"
        ]
    },
    "options_ui": {
        "page": "options.html"
    },
    "permissions": [
        "history",
        "nativeMessaging",
        "notifications",
        "tabGroups",
        "tabs",
        "storage",
        "webNavigation"
    ]
}